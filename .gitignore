# ─────────────────────────────────────────────────────────────
# Python (apps/api)
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
.venv/
venv/
env/
# Ignore local pyenv pins globally, but track apps/api's pin which determines
# the Python version for the project (uv reads this file during uv sync).
.python-version
!apps/api/.python-version

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/

# ─────────────────────────────────────────────────────────────
# Node / pnpm (apps/web + root)
# ─────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# Build output
dist/
build/
.svelte-kit/
*.tsbuildinfo

# Vite cache
.vite/

# ─────────────────────────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─────────────────────────────────────────────────────────────
# OS noise
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────
# Editors / IDEs
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# Tooling / runtime artefacts
# ─────────────────────────────────────────────────────────────
.fly/
.wrangler/
*.local

# ─────────────────────────────────────────────────────────────
# What is INTENTIONALLY tracked (do not add to this file):
#   apps/api/.python-version      ← committed (pins Python 3.11 for uv)
#   apps/api/uv.lock              ← committed (reproducible installs)
#   pnpm-lock.yaml                ← committed (frozen-install in CI)
#   apps/web/pnpm-lock.yaml       ← committed
#   apps/api/openapi.json         ← committed (CI freshness gate, T-013)
#   alembic/versions/*.py         ← committed (migration history)
#   .specify/, specs/, .github/   ← committed (project source of truth)
# ─────────────────────────────────────────────────────────────
