    "/api/v1/me/twists": {
      "get": {
        "description": "Return the caller's twists for the active chapter.\n\nThe handler is intentionally tolerant of \"no live chapter\" — that is\na normal state (between cycles, pre-ESTRENO) and the PWA renders an\nempty panel rather than an error.",
        "operationId": "getMeTwists",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List the caller's twists for the current live chapter",
        "tags": [
          "twists"
        ]
      }
    },
    "/api/v1/seasons/{slug}": {
      "get": {
        "description": "Resolve ``GET /seasons/{slug}`` per spec FR-005/FR-008.\n\nResponses:\n  * 200 — :class:`SeasonResponseDTO` with bible filtered to PUBLIC_BIBLE_KEYS.\n  * 503 — ``under_maintenance``.\n  * 404 — ``season_not_found``.",
        "operationId": "getSeasonBySlug",
        "parameters": [
          {
            "in": "path",
            "name": "slug",
            "required": true,
            "schema": {
              "title": "Slug",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeasonResponseDTO"
