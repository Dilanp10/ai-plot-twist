{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Health-check payload. ``checks`` is open-ended so modules can add keys.",
        "properties": {
          "checks": {
            "additionalProperties": {
              "enum": [
                "ok",
                "error"
              ],
              "type": "string"
            },
            "title": "Checks",
            "type": "object"
          },
          "status": {
            "enum": [
              "ok",
              "error"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "checks"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "TransitionAccepted": {
        "description": "202 response body. ``noop`` becomes ``False`` in module 003.",
        "properties": {
          "noop": {
            "default": true,
            "title": "Noop",
            "type": "boolean"
          },
          "status": {
            "const": "accepted",
            "default": "accepted",
            "title": "Status",
            "type": "string"
          }
        },
        "title": "TransitionAccepted",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "AI Plot Twist API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/internal/transition": {
      "post": {
        "description": "Validate semantic shape + replay-protect, then return a noop accept.\n\nOn replay (same ``trigger_id`` within this process), responds **409**\n``trigger_replayed`` per the contract.",
        "operationId": "postInternalTransition",
        "parameters": [
          {
            "in": "header",
            "name": "X-Tick-Signature",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Tick-Signature"
            }
          }
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransitionAccepted"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "HMAC-signed FSM transition trigger (stub in module 001)",
        "tags": [
          "internal"
        ]
      }
    },
    "/healthz": {
      "get": {
        "description": "Unauthenticated: 200 when DB is reachable, 503 otherwise.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness + DB health probe",
        "tags": [
          "system"
        ]
      }
    }
  }
}
