{
  "components": {
    "schemas": {
      "BreakdownDTO": {
        "description": "Per-decision counts; subset summed equals ``twist_count``.",
        "properties": {
          "approved": {
            "title": "Approved",
            "type": "integer"
          },
          "rejected_incoherent": {
            "title": "Rejected Incoherent",
            "type": "integer"
          },
          "rejected_offensive": {
            "title": "Rejected Offensive",
            "type": "integer"
          },
          "rejected_spam": {
            "title": "Rejected Spam",
            "type": "integer"
          }
        },
        "required": [
          "approved",
          "rejected_offensive",
          "rejected_incoherent",
          "rejected_spam"
        ],
        "title": "BreakdownDTO",
        "type": "object"
      },
      "ChapterDTO": {
        "properties": {
          "cliffhanger": {
            "title": "Cliffhanger",
            "type": "string"
          },
          "day_index": {
            "title": "Day Index",
            "type": "integer"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "panels": {
            "items": {
              "$ref": "#/components/schemas/PanelDTO"
            },
            "title": "Panels",
            "type": "array"
          },
          "released_at": {
            "format": "date-time",
            "title": "Released At",
            "type": "string"
          },
          "synopsis": {
            "title": "Synopsis",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "day_index",
          "title",
          "synopsis",
          "released_at",
          "panels",
          "cliffhanger"
        ],
        "title": "ChapterDTO",
        "type": "object"
      },
      "ChapterResponseDTO": {
        "properties": {
          "chapter": {
            "$ref": "#/components/schemas/ChapterDTO"
          },
          "season": {
            "$ref": "#/components/schemas/SeasonBriefDTO"
          }
        },
        "required": [
          "season",
          "chapter"
        ],
        "title": "ChapterResponseDTO",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Health-check payload. ``checks`` is open-ended so modules can add keys.",
        "properties": {
          "checks": {
            "additionalProperties": {
              "enum": [
                "ok",
                "error"
              ],
              "type": "string"
            },
            "title": "Checks",
            "type": "object"
          },
          "status": {
            "enum": [
              "ok",
              "error"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "checks"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "KillSwitchPayload": {
        "properties": {
          "on": {
            "title": "On",
            "type": "boolean"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          }
        },
        "required": [
          "on"
        ],
        "title": "KillSwitchPayload",
        "type": "object"
      },
      "MeResponse": {
        "properties": {
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        },
        "required": [
          "user"
        ],
        "title": "MeResponse",
        "type": "object"
      },
      "PanelDTO": {
        "properties": {
          "idx": {
            "title": "Idx",
            "type": "integer"
          },
          "image_blurhash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Blurhash"
          },
          "image_url": {
            "title": "Image Url",
            "type": "string"
          },
          "mood": {
            "title": "Mood",
            "type": "string"
          },
          "narration": {
            "title": "Narration",
            "type": "string"
          },
          "tts_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tts Url"
          }
        },
        "required": [
          "idx",
          "image_url",
          "narration",
          "mood"
        ],
        "title": "PanelDTO",
        "type": "object"
      },
      "PublicUser": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "display_name": {
            "title": "Display Name",
            "type": "string"
          },
          "last_seen_at": {
            "format": "date-time",
            "title": "Last Seen At",
            "type": "string"
          },
          "public_id": {
            "format": "uuid",
            "title": "Public Id",
            "type": "string"
          }
        },
        "required": [
          "public_id",
          "display_name",
          "created_at",
          "last_seen_at"
        ],
        "title": "PublicUser",
        "type": "object"
      },
      "RedeemRequest": {
        "properties": {
          "display_name": {
            "title": "Display Name",
            "type": "string"
          },
          "invite_code": {
            "title": "Invite Code",
            "type": "string"
          }
        },
        "required": [
          "invite_code",
          "display_name"
        ],
        "title": "RedeemRequest",
        "type": "object"
      },
      "RedeemResponse": {
        "properties": {
          "device_secret": {
            "title": "Device Secret",
            "type": "string"
          },
          "jwt": {
            "title": "Jwt",
            "type": "string"
          },
          "jwt_expires_at": {
            "format": "date-time",
            "title": "Jwt Expires At",
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        },
        "required": [
          "user",
          "jwt",
          "device_secret",
          "jwt_expires_at"
        ],
        "title": "RedeemResponse",
        "type": "object"
      },
      "RefreshRequest": {
        "properties": {
          "device_secret": {
            "title": "Device Secret",
            "type": "string"
          }
        },
        "required": [
          "device_secret"
        ],
        "title": "RefreshRequest",
        "type": "object"
      },
      "RefreshResponse": {
        "properties": {
          "jwt": {
            "title": "Jwt",
            "type": "string"
          },
          "jwt_expires_at": {
            "format": "date-time",
            "title": "Jwt Expires At",
            "type": "string"
          }
        },
        "required": [
          "jwt",
          "jwt_expires_at"
        ],
        "title": "RefreshResponse",
        "type": "object"
      },
      "ReplayPayload": {
        "description": "Body for ``POST /director/replay``.",
        "properties": {
          "chapter_id": {
            "description": "Chapter ``public_id`` (UUID) to re-classify.",
            "format": "uuid",
            "title": "Chapter Id",
            "type": "string"
          }
        },
        "required": [
          "chapter_id"
        ],
        "title": "ReplayPayload",
        "type": "object"
      },
      "ReplayResponse": {
        "properties": {
          "batches": {
            "title": "Batches",
            "type": "integer"
          },
          "breakdown": {
            "$ref": "#/components/schemas/BreakdownDTO"
          },
          "chapter_id": {
            "format": "uuid",
            "title": "Chapter Id",
            "type": "string"
          },
          "classified": {
            "title": "Classified",
            "type": "integer"
          },
          "default_denied": {
            "title": "Default Denied",
            "type": "integer"
          },
          "duration_ms": {
            "title": "Duration Ms",
            "type": "integer"
          },
          "slur_overrides": {
            "title": "Slur Overrides",
            "type": "integer"
          },
          "twist_count": {
            "title": "Twist Count",
            "type": "integer"
          }
        },
        "required": [
          "chapter_id",
          "twist_count",
          "classified",
          "batches",
          "breakdown",
          "default_denied",
          "slur_overrides",
          "duration_ms"
        ],
        "title": "ReplayResponse",
        "type": "object"
      },
      "SeasonBriefDTO": {
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "title"
        ],
        "title": "SeasonBriefDTO",
        "type": "object"
      },
      "SeasonFullDTO": {
        "properties": {
          "bible_public": {
            "additionalProperties": true,
            "title": "Bible Public",
            "type": "object"
          },
          "chapter_count": {
            "title": "Chapter Count",
            "type": "integer"
          },
          "current_day_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Current Day Index"
          },
          "ended_on": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Ended On"
          },
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "started_on": {
            "title": "Started On"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "title",
          "bible_public",
          "started_on",
          "chapter_count",
          "current_day_index"
        ],
        "title": "SeasonFullDTO",
        "type": "object"
      },
      "SeasonResponseDTO": {
        "properties": {
          "season": {
            "$ref": "#/components/schemas/SeasonFullDTO"
          }
        },
        "required": [
          "season"
        ],
        "title": "SeasonResponseDTO",
        "type": "object"
      },
      "SubmitRequest": {
        "description": "Request body for ``POST /twists/submit``.\n\n``content`` is validated by the domain normalizer (5..280 chars after\nNFKC + Cc/Cf/Co/Cs stripping + trim). The handler raises 422 on\nout-of-bounds values.",
        "properties": {
          "chapter_id": {
            "format": "uuid",
            "title": "Chapter Id",
            "type": "string"
          },
          "content": {
            "title": "Content",
            "type": "string"
          }
        },
        "required": [
          "chapter_id",
          "content"
        ],
        "title": "SubmitRequest",
        "type": "object"
      },
      "TodayResponseDTO": {
        "properties": {
          "chapter": {
            "$ref": "#/components/schemas/ChapterDTO"
          },
          "cycle_state": {
            "enum": [
              "PENDING_RELEASE",
              "ESTRENO",
              "RECEPCION_IDEAS",
              "FILTERING",
              "VOTACION",
              "GENERACION",
              "FAILED"
            ],
            "title": "Cycle State",
            "type": "string"
          },
          "season": {
            "$ref": "#/components/schemas/SeasonBriefDTO"
          },
          "windows": {
            "$ref": "#/components/schemas/WindowsDTO"
          }
        },
        "required": [
          "cycle_state",
          "season",
          "chapter",
          "windows"
        ],
        "title": "TodayResponseDTO",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VoteRequest": {
        "properties": {
          "twist_id": {
            "description": "UUID of the twist to vote for.",
            "format": "uuid",
            "title": "Twist Id",
            "type": "string"
          }
        },
        "required": [
          "twist_id"
        ],
        "title": "VoteRequest",
        "type": "object"
      },
      "WindowsDTO": {
        "properties": {
          "next_release": {
            "format": "date-time",
            "title": "Next Release",
            "type": "string"
          },
          "submit_until": {
            "format": "date-time",
            "title": "Submit Until",
            "type": "string"
          },
          "vote_from": {
            "format": "date-time",
            "title": "Vote From",
            "type": "string"
          },
          "vote_until": {
            "format": "date-time",
            "title": "Vote Until",
            "type": "string"
          }
        },
        "required": [
          "submit_until",
          "vote_from",
          "vote_until",
          "next_release"
        ],
        "title": "WindowsDTO",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "AI Plot Twist API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/me": {
      "get": {
        "description": "Return the authenticated user.  Side-effect: updates ``last_seen_at``.",
        "operationId": "getAuthMe",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Me",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/redeem-invite": {
      "post": {
        "description": "Redeem an invite code, create a user, and issue a JWT + device_secret.",
        "operationId": "postAuthRedeemInvite",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RedeemResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Redeem Invite",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "description": "Issue a fresh JWT from a valid device_secret.\n\nBanned users receive 401 (collapsed — same as invalid secret) to prevent\ninformation leakage about account status.",
        "operationId": "postAuthRefresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Refresh Token",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/chapters/today": {
      "get": {
        "description": "Resolve ``GET /chapters/today`` per spec FR-001/FR-002.\n\nResponses:\n  * 200 — :class:`TodayResponseDTO` + ETag + short-fresh + swr + must-revalidate.\n  * 304 — empty body, when ``If-None-Match`` matches the current ETag.\n  * 503 — ``under_maintenance`` (kill-switch on) or ``no_active_season``.\n  * 404 — ``no_live_chapter`` with ``first_release_at``.",
        "operationId": "getChaptersToday",
        "parameters": [
          {
            "in": "header",
            "name": "If-None-Match",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "If-None-Match"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodayResponseDTO"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Today's chapter + cycle state + window timestamps",
        "tags": [
          "chapters"
        ]
      }
    },
    "/api/v1/chapters/{public_id}": {
      "get": {
        "description": "Resolve ``GET /chapters/{public_id}`` per spec FR-004.\n\nResponses:\n  * 200 — :class:`ChapterResponseDTO` + ETag + Cache-Control.\n  * 304 — empty body when ``If-None-Match`` matches the ETag.\n  * 503 — ``under_maintenance``.\n  * 404 — ``chapter_not_found`` (unknown id OR pre-release status).",
        "operationId": "getChapterById",
        "parameters": [
          {
            "in": "path",
            "name": "public_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Public Id",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-None-Match",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "If-None-Match"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChapterResponseDTO"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Read a specific chapter (live or archived) by its public id",
        "tags": [
          "chapters"
        ]
      }
    },
    "/api/v1/internal/director/replay": {
      "post": {
        "description": "Re-classify every non-deleted twist of *chapter_id*.\n\nDoes NOT touch ``cycles.state``. Each batch commits inside\n:func:`run_director_filter`, so a partial failure leaves the\nearlier-batch updates persisted.",
        "operationId": "postInternalDirectorReplay",
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReplayPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReplayResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Re-run the director's filter for a chapter (admin-only)",
        "tags": [
          "internal"
        ]
      }
    },
    "/api/v1/internal/health/cycle": {
      "get": {
        "description": "Return a point-in-time snapshot of the active cycle's FSM state.",
        "operationId": "getInternalHealthCycle",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "FSM cycle health snapshot",
        "tags": [
          "internal"
        ]
      }
    },
    "/api/v1/internal/kill-switch": {
      "post": {
        "description": "Set the ``kill_switch`` system flag and return its new state.\n\nThe change is committed immediately; the in-process cache is invalidated\nso the next executor call reads the fresh DB value.",
        "operationId": "postInternalKillSwitch",
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KillSwitchPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Activate or deactivate the FSM kill-switch",
        "tags": [
          "internal"
        ]
      }
    },
    "/api/v1/internal/transition": {
      "post": {
        "description": "Validate semantic payload, dispatch to watchdog or FSM executor.\n\nCommits the DB session on success; the session is auto-rolled-back by the\nDI context manager if a domain exception escapes as a ``ProblemDetail``.",
        "operationId": "postInternalTransition",
        "parameters": [
          {
            "in": "header",
            "name": "X-Dev-Skip-Dwell",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Dev-Skip-Dwell"
            }
          },
          {
            "in": "header",
            "name": "X-Tick-Signature",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
