/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Phase 1 of the CSP rollout (see docs/adr/0005-csp-rollout.md):
# report-only so we get violations to /internal/client-log without
# breaking the app if some asset URL was missed. Phase 2 flips this
# header to enforcing once the violation feed is empty for 7 days.
  Content-Security-Policy-Report-Only: default-src 'self'; img-src 'self' https://pub-be7ca6cbc73949b89f94b411796f7bf1.r2.dev data: blob:; media-src 'self' https://pub-be7ca6cbc73949b89f94b411796f7bf1.r2.dev; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; report-uri /api/v1/internal/client-log

# SW must NOT be cached aggressively — the workbox-generated file is
# the one piece of the bundle whose update kicks off the update
# notifier (T-008).
/sw.js
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: public, max-age=300
