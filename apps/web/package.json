    "axe-core": "^4.12.1",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.0.0",
    "workbox-cacheable-response": "^7.4.1",
