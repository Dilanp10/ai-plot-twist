# ─────────────────────────────────────────────────────────────
# AI Plot Twist — environment variables (template)
#
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored.  In production (Fly.io) these are
# set via `fly secrets set KEY=VALUE` (one per `fly secrets set`
# call, or all in one call separated by spaces).
# ─────────────────────────────────────────────────────────────

# ── App identity ────────────────────────────────────────────────
# One of: dev | prod | test.
ENV=dev
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO

# ── Required (no default) ───────────────────────────────────────
# Async Postgres connection string.  In prod, Neon URL with the
# asyncpg driver: postgresql+asyncpg://<user>:<pass>@<host>/<db>
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/aiplottwist

# HS256 secret for issuing/validating JWTs (module 002+).
# Generate with: openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-change-me

# ── Cron / internal endpoints ───────────────────────────────────
# HMAC-SHA256 shared secret for /internal/transition calls from
# the GitHub Actions cron workflows.  If absent, every POST to
# /internal/* returns 503.
# Generate with: openssl rand -base64 32
TICK_SECRET=dev-tick-secret-change-me

# Bearer token for admin endpoints (rerun-filter, rerun-generation,
# push-test).  Absent → those endpoints return 503.
ADMIN_TOKEN=

# Discord webhook for cycle alerts (FAILED state, degraded chapter,
# watchdog escalation).  Absent → alerts are logged only.
DISCORD_WEBHOOK_URL=

# ── Cloudflare R2 (module 008 — image pipeline) ─────────────────
# All four required when generation_pipeline runs the real chain.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for serving R2 assets (e.g. https://assets.aiplottwist.example).
R2_PUBLIC_BASE_URL=

# ── Module 005 — twists ─────────────────────────────────────────
MAX_TWISTS_PER_USER_PER_CHAPTER=3

# ── Module 007 — voting ─────────────────────────────────────────
MAX_VOTES_PER_USER_PER_CHAPTER=5
# true in closed-beta; flip to false in open prod.
ALLOW_SELF_VOTE=true

# ── Module 006 — director's filter (LLM providers) ──────────────
# Either or both may be absent in dev/test; main.py warns and
# leaves the no-op stub registered.  Both set → real router.
GEMINI_API_KEY=
GITHUB_MODELS_TOKEN=

# ── Module 009 — image providers (T2I) ──────────────────────────
# HuggingFace token for the FLUX.1-schnell fallback. Required
# when generation_image_chain_env=mvp in prod.
HUGGINGFACE_TOKEN=
T2I_TIMEOUT_S=120
T2I_MAX_RETRIES=2
T2I_BACKOFF_SECONDS_CSV=2,8

# ── Module 008 — generation pipeline ────────────────────────────
# dev → Fake provider only; mvp → Pollinations + HuggingFace.
GENERATION_IMAGE_CHAIN_ENV=dev
# Static placeholder URL used when a panel fails.  Required for
# the real side-effect to wire.
GENERATION_PLACEHOLDER_URL=
# edge-tts voice (empty string disables TTS).
GENERATION_TTS_VOICE=es-AR-ElenaNeural
GENERATION_PANEL_CONCURRENCY=4
GENERATION_DEADLINE_S=600

# ── Module 011 — web push ───────────────────────────────────────
# Both required for the real fan-out side-effect.
# Generate with: pnpm generate-vapid
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:operator@aiplottwist.example
PUSH_FANOUT_TIMEOUT_S=60
PUSH_FANOUT_CONCURRENCY=8
PUSH_FAILURE_THRESHOLD=3
