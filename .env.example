# ─────────────────────────────────────────────────────────────
# AI Plot Twist — environment variables (template)
#
# Copy this file to `.env.local` and fill in your values. `.env.local`
# is gitignored. In production (Fly.io), these are set via
# `fly secrets set KEY=VALUE`.
# Every variable the application reads in module 001 is listed here.
# ─────────────────────────────────────────────────────────────

# Environment name. Affects logging verbosity and OpenAPI docs visibility.
# One of: dev | prod | test.
ENV=dev

# Log level. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO

# Async Postgres connection string. The local dev value below matches
# infra/docker-compose.dev.yml (port 5433 to avoid host conflicts).
# In prod, this is a Neon connection string using the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/aiplottwist

# Shared secret for HMAC-SHA256 signing of /internal/transition payloads
# sent by the GitHub Actions cron workflows. Any random string works for
# dev; in prod use 32+ random bytes (e.g. `openssl rand -base64 32`).
TICK_SECRET=dev-tick-secret-change-me

# HS256 secret for issuing/validating JWTs (module 002 onwards).
# Module 001 only validates it is set at boot; it is not yet used to sign.
JWT_SECRET=dev-jwt-secret-change-me

# Cloudflare R2 credentials — consumed by module 008 (image pipeline)
# to upload generated panels. Safe to leave empty in dev; code paths
# that need R2 will fail lazily at call time, not at boot.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
